PORT=5000
# Production Vercel URL (no trailing slash)
FRONTEND_URL=http://localhost:5173
# Optional: extra origins comma-separated (Vercel previews auto-allowed)
# ALLOWED_ORIGINS=https://hexcloud.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Required for server-side admin writes & background jobs (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=

# PostgreSQL (Prisma) — primary datastore for v2 API
DATABASE_URL=postgresql://hexcloud:hexcloud@localhost:5432/hexcloud

# JWT sessions (email OTP auth)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=
# Frontend: VITE_TURNSTILE_SITE_KEY

# VPS automation provider: demo | proxmox | virtualizor | solusvm
VPS_PROVIDER=demo
PROXMOX_HOST=
PROXMOX_TOKEN=

# Notifications
DISCORD_WEBHOOK_URL=
RESEND_API_KEY=

# Trial anti-abuse
TRIAL_COOLDOWN_DAYS=30
