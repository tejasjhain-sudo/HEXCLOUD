// HEXCloud — PostgreSQL schema (Prisma)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum TrialStatus {
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
  CANCELLED
}

enum VpsStatus {
  PROVISIONING
  RUNNING
  STOPPED
  ERROR
  DELETED
}

enum AbuseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BillingStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  emailVerifiedAt DateTime?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  planType        String     @default("FREE")
  walletBalance   Decimal    @default(0) @db.Decimal(12, 2)
  referralCode    String?    @unique
  referredById    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sessions      Session[]
  trials        Trial[]
  vpsInstances  VpsInstance[]
  abuseLogs     AbuseLog[]    @relation("AbuseTarget")
  billing       BillingRecord[]
  adminActions  AdminAction[] @relation("AdminActor")
  auditLogs     AuditLog[]

  @@index([email])
  @@index([status])
}

model Session {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String    @unique
  ipAddress    String?
  userAgent    String?
  fingerprint  String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([email])
}

model Trial {
  id              String      @id @default(uuid())
  userId          String
  status          TrialStatus @default(PENDING)
  creditsInr      Decimal     @default(10000) @db.Decimal(12, 2)
  startedAt       DateTime?
  expiresAt       DateTime?
  ipAddress       String?
  fingerprint     String?
  turnstilePassed Boolean     @default(false)
  approvedById    String?
  rejectedReason  String?
  adminNote       String?
  cooldownUntil   DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vpsInstances VpsInstance[]

  @@index([userId])
  @@index([status])
  @@index([fingerprint])
  @@index([ipAddress])
}

model VpsInstance {
  id              String    @id @default(uuid())
  userId          String
  trialId         String?
  externalId      String?
  provider        String    @default("demo")
  name            String
  status          VpsStatus @default(PROVISIONING)
  ipAddress       String?
  osType          String
  cpu             Int
  ramMb           Int
  storageGb       Int
  region          String?
  expiresAt       DateTime?
  lastHeartbeatAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trial Trial? @relation(fields: [trialId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([trialId])
  @@index([status])
}

model AbuseLog {
  id          String         @id @default(uuid())
  userId      String?
  ipAddress   String?
  fingerprint String?
  eventType   String
  severity    AbuseSeverity  @default(MEDIUM)
  metadata    Json?
  blocked     Boolean        @default(false)
  createdAt   DateTime       @default(now())

  user User? @relation("AbuseTarget", fields: [userId], references: [id], onDelete: SetNull)

  @@index([ipAddress])
  @@index([fingerprint])
  @@index([eventType])
}

model BillingRecord {
  id          String        @id @default(uuid())
  userId      String
  amountInr   Decimal       @db.Decimal(12, 2)
  status      BillingStatus @default(PENDING)
  provider    String?
  externalId  String?
  description String?
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  admin User @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  service   String
  action    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([service])
  @@index([createdAt])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider])
}

model ReferralPlaceholder {
  id             String   @id @default(uuid())
  code           String   @unique
  ownerUserId    String?
  rewardCredits  Decimal  @default(0) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
}
