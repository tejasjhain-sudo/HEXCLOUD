VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API — local dev or Render URL (must end with /api)
# Local:  http://localhost:5000/api
# Render: https://hexcloud-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Socket.io uses the same host as VITE_API_URL without /api
VITE_RAZORPAY_KEY_ID=rzp_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional — Groq API for in-app AI chatbot (https://console.groq.com)
VITE_GROQ_API_KEY=
